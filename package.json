{
  "name": "aadhaarchain",
  "version": "1.0.0",
  "description": "Self-sovereign identity platform bridging India's government-grade identity verification with decentralized ownership",
  "private": true,
  "workspaces": [
    "packages/*",
    "programs/*"
  ],
  "scripts": {
    "build": "yarn workspaces run build",
    "test": "yarn workspaces run test",
    "dev": "yarn workspaces run dev",
